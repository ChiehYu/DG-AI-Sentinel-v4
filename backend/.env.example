# ==============================================================================
# DG AI Sentinel V3.0 後台系統環境變數設定範本
# 請將此檔案複製或重命名為 .env 並填入對應 API 金鑰
# ==============================================================================

# 1. Google Gemini 3.1 Pro API (10輪對抗沙盤推演引擎專用)
# 可於 Google AI Studio (https://aistudio.google.com/) 申請
GEMINI_API_KEY="your_gemini_api_key_here"

# 2. Fugle 富果 API (取得即時股價與籌碼)
FUGLE_API_KEY="your_fugle_api_key_here"

# 3. 早晨 08:30 手機推播管道 (任選填寫或同時啟用)
# Line Notify 權杖
LINE_NOTIFY_TOKEN=""

# Telegram Bot 推播 (Bot Token 與 Chat ID)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# 4. 系統設定
# 預設旗艦防守標的代號
DEFAULT_FLAGSHIP_SYMBOL="00919"
# 信貸總投入金額 (NTD)
CREDIT_LOAN_TOTAL="2000000"
